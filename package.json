{
  "name": "locent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm -F @locent/client dev",
    "dev:server": "pnpm -F @locent/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "deploy:server": "./_ci/deploy-server.sh"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
